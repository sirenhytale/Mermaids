$C = "../Common.ui";

@MermaidButtonStyle = TextButtonStyle(
    Default: (Background: #4a5568, LabelStyle: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
    Hovered: (Background: #5a6578, LabelStyle: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
    Pressed: (Background: #3a4558, LabelStyle: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

Group{
    Anchor: (Width: 720, Height: 580);
    Background: #1a1a2e(0.98);
    LayoutMode: Top;
    Padding: (Full: 20);

    Label {
        Text: "Mermaids";
        Anchor: (Height: 36);
        Style: (FontSize: 24, TextColor: #ffffff, HorizontalAlignment: Center, RenderBold: true);
    }

    Group { Anchor: (Height: 1); Background: #2b3542; }
    Group { Anchor: (Height: 12); }

    Label {
        Text: "Tail Model";
        Anchor: (Height: 30);
        Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center, RenderBold: true);
    }

    Group { Anchor: (Height: 18); }

    Group {
        LayoutMode: Left;
        Anchor: (Height: 36);

        TextButton #OriginalMermaidSmallFinButton {
            Text: "Mermaid Small Tail Fins";
            Anchor: (Width: 150, Height: 60);
            Style: @MermaidButtonStyle;
        }

        $C.@TextField #MermaidPlayer {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayer";
            }

        TextButton #OriginalMermaidBigFinButton {
            Text: "Mermaid Big Tail Fins";
            Anchor: (Width: 150, Height: 60);
            Style: @MermaidButtonStyle;
        }

        $C.@TextField #MermaidBigFinPlayer {
            Anchor: (Height: 0);
            PlaceholderText: "";
            Style: (FontSize: 0);
            Value: "MermaidBigFinPlayer";
        }
    }

    Group { Anchor: (Height: 28); }
    Group { Anchor: (Height: 1); Background: #2b3542; }
    Group { Anchor: (Height: 12); }

    Label {
        Text: "Tail Color";
        Anchor: (Height: 30);
        Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center, RenderBold: true);
    }

    Group { Anchor: (Height: 18); }

    Group {
        LayoutMode: Top;
        Anchor: (Height: 168);

        Group {
            LayoutMode: Left;
            Anchor: (Height: 36);

            TextButton #OrangeTailColorButton {
                Text: "Orange";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #OrangeTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerGrayscale";
            }

            TextButton #YellowTailColorButton {
                Text: "Yellow";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #YellowTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerYellow";
            }

            TextButton #RedTailColorButton {
                Text: "Red";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #RedTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerRed";
            }

            TextButton #BlueTailColorButton {
                Text: "Light Blue";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #BlueTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerBlue";
            }

            TextButton #DBlueTailColorButton {
                Text: "Blue";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #DBlueTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerDBlue";
            }

            TextButton #PurpleTailColorButton {
                Text: "Light Purple";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #PurpleTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerPurple";
            }
        }

        Group { Anchor: (Height: 36); }

        Group {
            LayoutMode: Left;
            Anchor: (Height: 36);

            TextButton #DPurpleTailColorButton {
                Text: "Purple";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #DPurpleTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerDPurple";
            }

            TextButton #PinkTailColorButton {
                Text: "Pink";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #PinkTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerPink";
            }

            TextButton #LimeTailColorButton {
                Text: "Green";
                Anchor: (Width: 90, Height: 60);
                Style: @MermaidButtonStyle;
            }

            $C.@TextField #LimeTailColor {
                Anchor: (Height: 0);
                PlaceholderText: "";
                Style: (FontSize: 0);
                Value: "MermaidPlayerLime";
            }
        }
    }
}