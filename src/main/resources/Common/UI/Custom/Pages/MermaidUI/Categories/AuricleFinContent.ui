$C = "../../../Common.ui";
$SB = "../SelectorButton.ui";

Group {
  LayoutMode: Top;

  Group {
    Anchor: (Bottom: 25);
    LayoutMode: Top;

    Group #AuricleFin0 {
      $SB.@SelectorBlock {
        @Name = "None";
      }
    }

    Group #AuricleFin1 {
      $SB.@SelectorBlock {
        @Name = "Ear Fins";
      }
    }

    Group #AuricleFin2 {
      $SB.@SelectorBlock {
        @Name = "Spiked Ear Fins";
      }
    }
  }
}
