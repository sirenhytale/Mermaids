$C = "../../../Common.ui";
$SB = "../SelectorButton.ui";

Group {
  LayoutMode: Top;

  Group {
    Anchor: (Bottom: 25);
    LayoutMode: Top;

    Group #TailColor0 {
      $SB.@SelectorBlock {
        @Name = "Orange Tail";
      }
    }

    Group #TailColor1 {
      $SB.@SelectorBlock {
        @Name = "Pink Tail";
      }
    }

    Group #TailColor2 {
      $SB.@SelectorBlock {
        @Name = "Purple Tail";
      }
    }


    Group #TailColor3 {
      $SB.@SelectorBlock {
        @Name = "Rose Tail";
      }
    }

    Group #TailColor4 {
      $SB.@SelectorBlock {
        @Name = "Lime Tail";
      }
    }

    Group #TailColor5 {
      $SB.@SelectorBlock {
        @Name = "Blue Tail";
      }
    }

    Group #TailColor6 {
      $SB.@SelectorBlock {
        @Name = "Aqua Tail";
      }
    }

    Group #TailColor7 {
      $SB.@SelectorBlock {
        @Name = "Cyan Tail";
      }
    }
  }
}
