$C = "../../../Common.ui";
$SB = "../SelectorButton.ui";

Group {
  LayoutMode: Top;

  Group {
    Anchor: (Bottom: 25);
    LayoutMode: Top;

    Group #PectoralFin0 {
      $SB.@SelectorBlock {
        @Name = "None";
      }
    }

    Group #PectoralFin1 {
      $SB.@SelectorBlock {
        @Name = "Full Side";
      }
    }
  }
}
